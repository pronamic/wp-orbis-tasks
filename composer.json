{
	"name": "pronamic/wp-orbis-tasks",
	"description": "The Orbis Tasks plugin extends your Orbis environment with the option to add tasks and connect them to Orbis projects.",
	"license": "GPL-2.0-or-later",
	"type": "wordpress-plugin",
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true,
			"automattic/jetpack-autoloader": true
		},
		"wp-slug": "orbis-tasks"
	},
	"autoload": {
		"files": [
			"includes/functions.php"
		],
		"psr-4": {
			"Pronamic\\Orbis\\Tasks\\": "classes/"
		}
	},
	"require": {
		"automattic/jetpack-autoloader": "^3.0",
		"woocommerce/action-scheduler": "^3.7",
		"pronamic/wp-datetime": "^2.1"
	},
	"require-dev": {
		"pronamic/wp-coding-standards": "^2.1",
		"roots/wordpress-no-content": "^6.4",
		"wp-cli/dist-archive-command": "*",
		"wp-cli/wp-cli-bundle": "*"
	},
	"scripts": {
		"build": [
			"rm -rf ./build/stage-1",
			"rm -rf ./build/orbis-tasks/*",
			"rsync --recursive --verbose --exclude-from=.distignore --exclude=/vendor/ ./ ./build/stage-1/",
			"composer install --no-dev --prefer-dist --optimize-autoloader --working-dir=./build/stage-1/",
			"rsync --recursive --verbose --exclude-from=.distignore ./build/stage-1/ ./build/orbis-tasks/",
			"vendor/bin/wp i18n make-pot ./build/orbis-tasks/ --slug=orbis-tasks",
			"vendor/bin/wp i18n make-mo ./build/orbis-tasks/languages/",
			"vendor/bin/wp dist-archive ./build/orbis-tasks/ --plugin-dirname=orbis-tasks --force"
		],
		"make-pot": [
			"@build",
			"rsync --recursive --delete --verbose ./build/orbis-tasks/languages/ ./languages/",
			"vendor/bin/wp i18n update-po ./languages/orbis-tasks.pot"
		]
	}
}
